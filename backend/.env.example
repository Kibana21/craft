# CRAFT backend environment template.
#
# Copy to `.env` and fill in your values. `.env` is git-ignored.
# Every key here is read by app/core/config.py:Settings — keep this file in
# sync with that class.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=CRAFT
DEBUG=true                       # false in production

# ── Database ─────────────────────────────────────────────────────────────────
# Local Postgres. asyncpg driver is required (sqlalchemy async).
DATABASE_URL=postgresql+asyncpg://content_forge_user:CHANGE_ME@localhost:5432/craft_db

# ── Redis ────────────────────────────────────────────────────────────────────
# Used for: Celery broker + result backend, leaderboard sorted set, daily
# variation quotas (poster + studio). App degrades gracefully if Redis is
# unreachable but features dependent on it stop working.
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT_SECRET MUST be rotated for production. Use a 64+ char random string.
JWT_SECRET=dev-only-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ── S3 / R2 storage (optional) ────────────────────────────────────────────────
# Leave S3_BUCKET empty in dev to use the local backend/uploads/ fallback.
S3_BUCKET=
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=                 # set for R2 or custom S3-compatible endpoints

# ── Google AI (Gemini text + image) ──────────────────────────────────────────
# Used for: prompt-builder, copy-draft, brief-improve, image generation
# (gemini-2.5-flash-image), inpainting, refinement.
GOOGLE_API_KEY=

# ── Google Veo (Vertex AI video generation) ──────────────────────────────────
# Service-account JSON path — RELATIVE to the backend working dir.
# The lifespan startup will warmup the Vertex client on boot; if this file is
# missing the warning is logged but the app still starts (video features fail).
GOOGLE_VEO_KEY_FILE=video-key.json
VEO_PROJECT_ID=gen-lang-client-0913704662
VEO_LOCATION=us-central1
VEO_MODEL_ID=veo-3.0-generate-001
VEO_SCENE_TIMEOUT_SECONDS=900    # 15 min per scene
VIDEO_POLL_INTERVAL_SECONDS=5

# ── Frontend ─────────────────────────────────────────────────────────────────
# Used for CORS allow-list. Must match the origin the browser uses to load the
# Next.js dev server. Set to the production URL when deploying.
FRONTEND_URL=http://localhost:3000
